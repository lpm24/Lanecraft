{
  "rules": {
    ".read": false,
    ".write": false,

    "parties": {
      ".indexOn": ["status"],
      ".read": "auth != null",

      "$code": {
        ".read": "auth != null",

        // Allow creation (party doesn't exist yet) or full delete by host
        ".write": "auth != null && (
          (!data.exists() && newData.exists()) ||
          (data.exists() && data.child('hostUid').val() === auth.uid && !newData.exists())
        )",

        ".validate": "newData.hasChildren(['code', 'hostUid', 'players', 'maxSlots', 'mapId', 'status', 'seed'])",

        "code": {
          ".validate": "newData.isString() && newData.val().length >= 4 && newData.val().length <= 6"
        },
        "hostUid": {
          ".validate": "newData.isString() && newData.val().length <= 128"
        },
        "seed": {
          ".write": "auth != null && data.parent().child('hostUid').val() === auth.uid",
          ".validate": "newData.isNumber()"
        },
        "maxSlots": {
          ".write": "auth != null && data.parent().child('hostUid').val() === auth.uid",
          ".validate": "newData.isNumber() && newData.val() >= 2 && newData.val() <= 8"
        },
        "mapId": {
          ".write": "auth != null && data.parent().child('hostUid').val() === auth.uid",
          ".validate": "newData.isString() && newData.val().length <= 20"
        },
        "status": {
          ".write": "auth != null && data.parent().child('hostUid').val() === auth.uid",
          ".validate": "newData.isString() && (
            newData.val() === 'waiting' ||
            newData.val() === 'starting' ||
            newData.val() === 'in_game' ||
            newData.val() === 'ended'
          )"
        },
        "teamSize": {
          ".write": "auth != null && data.parent().child('hostUid').val() === auth.uid",
          ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 4"
        },
        "difficulty": {
          ".write": "auth != null && data.parent().child('hostUid').val() === auth.uid",
          ".validate": "newData.isString() && newData.val().length <= 20"
        },
        "players": {
          "$slot": {
            // Player can write their own slot, or host can write any slot
            // Slot 0 is always the host
            ".write": "auth != null && (
              !data.exists() ||
              data.child('uid').val() === auth.uid ||
              data.parent().parent().child('hostUid').val() === auth.uid
            )",
            ".validate": "newData.hasChildren(['uid', 'name', 'race'])",
            "uid": { ".validate": "newData.isString() && newData.val().length <= 128" },
            "name": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 30" },
            "race": { ".validate": "newData.isString() && newData.val().length <= 20" }
          }
        },
        "bots": {
          "$slot": {
            ".write": "auth != null && data.parent().parent().child('hostUid').val() === auth.uid",
            ".validate": "newData.isString() && newData.val().length <= 20"
          }
        },
        "botRaces": {
          "$slot": {
            ".write": "auth != null && data.parent().parent().child('hostUid').val() === auth.uid",
            ".validate": "newData.isString() && newData.val().length <= 20"
          }
        },
        "hostPing": {
          ".write": "auth != null && data.parent().child('hostUid').val() === auth.uid",
          ".validate": "newData.isNumber()"
        },
        "fogOfWar": {
          ".write": "auth != null && data.parent().child('hostUid').val() === auth.uid",
          ".validate": "newData.isBoolean()"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        }
      }
    },

    "games": {
      "$code": {
        ".read": "auth != null",
        // Any participant can delete the game node (cleanup after match ends)
        ".write": "auth != null && !newData.exists()",

        "ready": {
          "$slot": {
            // Only the player assigned to this slot can write/remove their ready signal
            ".write": "auth != null && root.child('parties/' + $code + '/players/' + $slot + '/uid').val() === auth.uid",
            ".validate": "newData.isBoolean()"
          }
        },
        "turns": {
          "$turn": {
            // Allow turn-level deletion for cleanup by any participant
            ".write": "auth != null && !newData.exists()",
            "$slot": {
              // Only the player assigned to this slot can write turn data
              ".write": "auth != null && root.child('parties/' + $code + '/players/' + $slot + '/uid').val() === auth.uid",
              ".validate": "newData.hasChild('t') && newData.child('t').isNumber()"
            }
          }
        },
        "ping": {
          "$slot": {
            ".write": "auth != null && root.child('parties/' + $code + '/players/' + $slot + '/uid').val() === auth.uid",
            ".validate": "newData.isNumber()"
          }
        },
        "left": {
          "$slot": {
            // Only the player assigned to this slot can signal they left
            ".write": "auth != null && root.child('parties/' + $code + '/players/' + $slot + '/uid').val() === auth.uid",
            ".validate": "newData.isBoolean()"
          }
        }
      }
    }
  }
}
