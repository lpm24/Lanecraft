{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "outDir": "./dist-simtest",
    "rootDir": "./src"
  },
  "include": [
    "src/simulation/**/*.ts",
    "src/tests/simSmoke.ts"
  ]
}
